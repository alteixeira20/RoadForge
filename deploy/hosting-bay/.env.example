POSTGRES_PASSWORD=change-me-generate-a-long-random-password

ROADFORGE_ENVIRONMENT=production
# Set a real 32+ character random secret before production.
# ROADFORGE_SECRET_KEY=change-me-generate-at-least-32-random-characters
# Set to the trusted reverse proxy IPs/CIDRs that may supply forwarded client IP headers.
# ROADFORGE_TRUSTED_PROXY_IPS=10.0.0.10,10.0.1.0/24

NEXT_PUBLIC_API_URL=https://roadforge.alexandreteixeira.dev
ROADFORGE_WEB_BASE_URL=https://roadforge.alexandreteixeira.dev
ROADFORGE_CORS_ORIGINS=https://roadforge.alexandreteixeira.dev

# Redis is provisioned for realtime coordination. Keep memory active unless
# explicitly validating Redis-backed realtime or approved multi-worker mode.
REDIS_URL=redis://roadforge-redis:6379/0
ROADFORGE_REALTIME_BACKEND=memory
ROADFORGE_REDIS_KEY_PREFIX=roadforge:prod

# Keep production single-worker by default. Values greater than 1 require
# ROADFORGE_REALTIME_BACKEND=redis and completed RF-886 manual validation.
ROADFORGE_API_WORKERS=1
