# ─── Frontend (apps/web) ───────────────────────────────────────────────────────
# Base URL for the backend API. Copy this file to .env.local and set the value
# before running the Next.js dev server with a live backend.
NEXT_PUBLIC_API_URL=http://localhost:7878

# ─── Backend (apps/api) ────────────────────────────────────────────────────────
# PostgreSQL connection string used by the FastAPI app and Alembic.
DATABASE_URL=postgresql+asyncpg://roadforge:roadforge_dev@localhost:5432/roadforge

# PostgreSQL credentials (used by Docker Compose to initialise the database).
POSTGRES_DB=roadforge
POSTGRES_USER=roadforge
POSTGRES_PASSWORD=roadforge_dev

# Application environment — controls SQL echo, log verbosity, etc.
ROADFORGE_ENVIRONMENT=development
