# ─── Frontend (apps/web) ───────────────────────────────────────────────────────
# Base URL for the backend API. Copy this file to .env.local and set the value
# before running the Next.js dev server with a live backend.
NEXT_PUBLIC_API_URL=http://localhost:7878

# ─── Backend (apps/api) ────────────────────────────────────────────────────────
# PostgreSQL connection string used by the FastAPI app and Alembic when run from
# the host (outside Docker). Docker maps Postgres to localhost:5433 to avoid
# conflicts with a host Postgres on 5432. Services inside Docker use postgres:5432
# via the internal network (set in docker-compose.yml and not from this file).
DATABASE_URL=postgresql+asyncpg://roadforge:roadforge_dev@localhost:5433/roadforge

# PostgreSQL credentials (used by Docker Compose to initialise the database).
POSTGRES_DB=roadforge
POSTGRES_USER=roadforge
POSTGRES_PASSWORD=roadforge_dev

# Application environment — controls SQL echo, log verbosity, etc.
ROADFORGE_ENVIRONMENT=development

# Base URL of the Next.js frontend — used to build /join invite link URLs.
ROADFORGE_WEB_BASE_URL=http://localhost:3000
